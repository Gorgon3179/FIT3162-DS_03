# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# JWT Secret - change this to a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this

# Database (your friend will fill this in)
DATABASE_URL=postgresql://user:password@localhost:5432/monashvote
# OR individual fields:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=monashvote
DB_USER=postgres
DB_PASSWORD=yourpassword

# Email (for verification codes)
# In dev mode, codes are printed to console - no email setup needed
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Dev mode: skips real email sending, prints code to console
DEV_MODE=true
