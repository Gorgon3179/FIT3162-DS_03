# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=3000
NODE_ENV=development

# JWT Secret — change to a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this

# Supabase PostgreSQL connection string
# Get this from Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Voter hash salt — used to derive anonymous voter ID from email
VOTER_HASH_SALT=monashvote_salt

# Email (verification codes) — optional, codes printed to console if not set
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
