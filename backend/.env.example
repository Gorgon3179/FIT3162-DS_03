# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=3000
NODE_ENV=development

# JWT Secret — change to a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this

# Supabase PostgreSQL connection string
# Get this from Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Voter hash salt — used to derive anonymous voter ID from email
VOTER_HASH_SALT=monashvote_salt

# Email — SMTP (verification codes)
# DEV_MODE=true or empty EMAIL_USER → codes printed to console
# DEV_MODE=false + EMAIL_USER set → real emails sent
# Brevo (300 free/day): sign up at brevo.com, get SMTP key
#   EMAIL_HOST=smtp-relay.brevo.com
#   EMAIL_PORT=587
#   EMAIL_USER=apikey
#   EMAIL_PASS=xsmtpsib-...   (your Brevo SMTP key)
# Or Gmail:
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USER=your.name@gmail.com
#   EMAIL_PASS=...            (Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=your-verified-sender@example.com
DEV_MODE=true
