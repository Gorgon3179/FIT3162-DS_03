# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=3000
NODE_ENV=development

# JWT Secret — change to a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this

# Supabase PostgreSQL connection string
# Get from Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Voter hash salt — used to derive anonymous voter ID from email
VOTER_HASH_SALT=monashvote_salt

# Supabase API (public values used by Google login and Edge Functions)
# Get from Supabase Dashboard → Project Settings → API
# Also add http://localhost:3000/auth-callback.html to Supabase Auth → URL Configuration → Redirect URLs
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# Email — SMTP fallback (only used if Edge Function is unavailable)
# DEV_MODE=true → codes printed to console (no real email)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
DEV_MODE=true
